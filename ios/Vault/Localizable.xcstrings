        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "給油・走行・整備データが自動で記録に反映"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "油耗·行驶·保养数据自动记入账本"
          }
        }
      }
    },
    "무엇이 채워지나요": {
      "localizations": {
        "en": {
