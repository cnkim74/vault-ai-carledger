        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leave your questions or issues. Add your email and we'll reply."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ご質問やご不便な点をお書きください。メールをご記入いただければ返信します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
