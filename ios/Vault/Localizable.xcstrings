          "stringUnit": {
            "state": "translated",
            "value": "Connect to the port under the dash (most cars after 2005)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "運転席下の診断端子に接続（2005年以降の多くの車）"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接方向盘下方的诊断口（2005年后多数车型）"
          }
        }
      }
    },
    "블루투스로 연결": {
      "localizations": {
