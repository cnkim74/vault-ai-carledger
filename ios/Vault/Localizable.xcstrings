            "value": "整備警告(DTC)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保养警告(DTC)"
          }
        }
      }
    },
    "주행 트립": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trip distance"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "走行トリップ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "行程"
          }
        }
      }
    },
    "iPhone은 BLE(저전력 블루투스) 동글만 지원해요. 저가 ‘블루투스 클래식’ ELM327은 iOS에서 동작하지 않으니 아래 목록에서 고르세요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone supports only BLE (low-energy Bluetooth) dongles. Cheap ‘Bluetooth Classic’ ELM327 units don't work on iOS — pick from the list below."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneはBLE（低消費電力Bluetooth）ドングルのみ対応。安価な『Bluetoothクラシック』ELM327はiOSで動作しないため、下記から選んでください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone仅支持BLE（低功耗蓝牙）设备。廉价的‘经典蓝牙’ELM327在iOS上无法使用，请从下方选择。"
          }
        }
      }
    },
    "iOS 호환 추천 동글": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recommended iOS-compatible dongles"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS対応おすすめドングル"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS兼容推荐设备"
          }
        }
      }
    },
    "추천": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Top pick"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "おすすめ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推荐"
          }
        }
      }
    },
    "가성비": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Value"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コスパ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高性价比"
          }
        }
      }
    },
    "전기차 배터리 잔량은 표준 OBD로 안 나와요. 전기차는 테슬라 연동이 더 정확하고, 동글은 내연기관차에 강력해요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "EV battery level isn't exposed via standard OBD. For EVs, Tesla sync is more accurate; dongles shine for gas cars."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "EVのバッテリー残量は標準OBDでは取得できません。EVはテスラ連携が正確で、ドングルはガソリン車に強力です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标准OBD无法读取电动车电量。电动车用特斯拉同步更准确，OBD设备更适合燃油车。"
          }
        }
      }
    },
    "동글 연결 준비하기": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get ready to connect"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続の準備をする"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "准备连接"
          }
        }
      }
    },
    "프리미엄으로 동글 연동": {
      "localizations": {
