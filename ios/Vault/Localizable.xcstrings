          "stringUnit": {
            "state": "translated",
            "value": "OBD设备同步"
          }
        }
      }
    },
    "곧 제공돼요": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Coming soon"
          }
        },
        "ja": {
          "stringUnit": {
