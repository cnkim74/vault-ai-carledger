import Foundation

/// ios/Vault/Secrets.swift로 복사한 뒤 값을 채우세요.
/// (Supabase 대시보드 → Project Settings → API)
enum Secrets {
    static let supabaseURL = URL(string: "https://YOUR_PROJECT_REF.supabase.co")
    static let supabaseKey: String? = "YOUR_PUBLISHABLE_KEY"

    /// Anthropic API 키 (console.anthropic.com → API Keys)
    /// 비워 두면 AI 인사이트는 기본 문구로 동작합니다.
    static let anthropicKey: String? = nil
}
